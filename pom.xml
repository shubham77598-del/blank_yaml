<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <groupId>com.example</groupId>
    <artifactId>apigee-design-automation</artifactId>
    <version>1.0-SNAPSHOT</version>
    <packaging>pom</packaging>

    <properties>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <maven.compiler.source>1.8</maven.compiler.source>
        <maven.compiler.target>1.8</maven.compiler.target>
        <apigee.config.plugin.version>2.5.1</apigee.config.plugin.version>
        <!-- Credentials will be injected by GitHub Actions environment variables -->
        <apigee.org>${env.APIGEE_ORG}</apigee.org>
        <apigee.env>${env.APIGEE_ENV}</apigee.env>
        <apigee.token>${env.APIGEE_TOKEN}</apigee.token>
    </properties>

    <!-- Add this repositories section to find the Apigee Maven plugin -->
    <repositories>
        <repository>
            <id>central</id>
            <name>Central Repository</name>
            <url>https://repo.maven.apache.org/maven2</url>
        </repository>
        <repository>
            <id>apigee-repo</id>
            <name>Apigee Maven Repository</name>
            <url>https://maven.google.com</url>
            <releases>
                <enabled>true</enabled>
                <updatePolicy>daily</updatePolicy>
            </releases>
            <snapshots>
                <enabled>false</enabled>
            </snapshots>
        </repository>
    </repositories>

    <!-- Add this pluginRepositories section as well -->
    <pluginRepositories>
        <pluginRepository>
            <id>central</id>
            <name>Central Repository</name>
            <url>https://repo.maven.apache.org/maven2</url>
        </pluginRepository>
        <pluginRepository>
            <id>apigee-repo</id>
            <name>Apigee Maven Repository</name>
            <url>https://maven.google.com</url>
            <releases>
                <enabled>true</enabled>
                <updatePolicy>daily</updatePolicy>
            </releases>
            <snapshots>
                <enabled>false</enabled>
            </snapshots>
        </pluginRepository>
    </pluginRepositories>

    <dependencies>
        <dependency>
            <groupId>org.yaml</groupId>
            <artifactId>snakeyaml</artifactId>
            <version>2.2</version>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <!-- This plugin runs the custom Java code to parse YAML and generate bundles -->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>exec-maven-plugin</artifactId>
                <version>3.2.0</version>
                <executions>
                    <execution>
                        <id>generate-apigee-bundles-from-yaml</id>
                        <phase>generate-resources</phase>
                        <goals>
                            <goal>java</goal>
                        </goals>
                        <configuration>
                            <mainClass>com.example.DesignParser</mainClass>
                            <cleanupDaemonThreads>false</cleanupDaemonThreads>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!-- This is the official Apigee plugin for deploying configurations -->
            <plugin>
                <groupId>com.apigee.edge.config</groupId>
                <artifactId>apigee-config-maven-plugin</artifactId>
                <version>${apigee.config.plugin.version}</version>
                <executions>
                    <!-- EXECUTION 1: Deploy SharedFlows FIRST -->
                    <execution>
                        <id>deploy-sharedflows</id>
                        <phase>install</phase>
                        <goals>
                            <goal>sharedflows</goal>
                        </goals>
                        <configuration>
                            <!-- Deploys all bundles found in the target/sharedflows directory -->
                            <sharedflow.dir>${project.build.directory}/sharedflows</sharedflow.dir>
                        </configuration>
                    </execution>
                    <!-- EXECUTION 2: Deploy API Proxies SECOND -->
                    <execution>
                        <id>deploy-proxies</id>
                        <phase>install</phase>
                        <goals>
                            <goal>apiproxies</goal>
                        </goals>
                        <configuration>
                            <!-- Deploys all bundles found in the target/apiproxies directory -->
                            <apiproxy.dir>${project.build.directory}/apiproxies</apiproxy.dir>
                        </configuration>
                    </execution>
                </executions>
                <!-- Common configuration for all executions -->
                <configuration>
                    <org>${apigee.org}</org>
                    <token>${apigee.token}</token> <!-- Authentication via automated Service Account token -->
                    <apigee.hosturl>https://apigee.googleapis.com</apigee.hosturl>
                    <apigee.apiversion>v1</apigee.apiversion>
                    <apigee.config.options>update</apigee.config.options> <!-- The deployment strategy -->
                    <skip>false</skip>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>