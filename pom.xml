<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <groupId>com.example</groupId>
    <artifactId>apigee-design-automation</artifactId>
    <version>1.0-SNAPSHOT</version>
    <packaging>pom</packaging>

    <properties>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <maven.compiler.source>1.8</maven.compiler.source>
        <maven.compiler.target>1.8</maven.compiler.target>
        <!-- Use the latest version from the official repo -->
        <apigee.deploy.plugin.version>2.1.0</apigee.deploy.plugin.version>
        <!-- Credentials will be injected by GitHub Actions environment variables -->
        <apigee.org>${env.APIGEE_ORG}</apigee.org>
        <apigee.env>${env.APIGEE_ENV}</apigee.env>
        <apigee.bearer>${env.APIGEE_TOKEN}</apigee.bearer>
    </properties>

    <dependencies>
        <dependency>
            <groupId>org.yaml</groupId>
            <artifactId>snakeyaml</artifactId>
            <version>2.2</version>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <!-- This plugin runs the custom Java code to parse YAML and generate bundles -->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>exec-maven-plugin</artifactId>
                <version>3.2.0</version>
                <executions>
                    <execution>
                        <id>generate-apigee-bundles-from-yaml</id>
                        <phase>generate-resources</phase>
                        <goals>
                            <goal>java</goal>
                        </goals>
                        <configuration>
                            <mainClass>com.example.DesignParser</mainClass>
                            <cleanupDaemonThreads>false</cleanupDaemonThreads>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!-- Apigee Deploy Maven Plugin - for Shared Flows -->
            <plugin>
                <groupId>com.apigee.edge.config</groupId>
                <artifactId>apigee-edge-maven-plugin</artifactId>
                <version>${apigee.deploy.plugin.version}</version>
                <executions>
                    <execution>
                        <id>deploy-shared-flows</id>
                        <phase>install</phase>
                        <goals>
                            <goal>deploy</goal>
                        </goals>
                        <configuration>
                            <bundleType>sharedflow</bundleType>
                            <apiName>security-flow</apiName>
                            <options>update</options>
                            <directory>${project.build.directory}/sharedflows</directory>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!-- Apigee Deploy Maven Plugin - for API Proxies -->
            <plugin>
                <groupId>com.apigee.edge.config</groupId>
                <artifactId>apigee-edge-maven-plugin</artifactId>
                <version>${apigee.deploy.plugin.version}</version>
                <executions>
                    <execution>
                        <id>deploy-api-proxies</id>
                        <phase>install</phase>
                        <goals>
                            <goal>deploy</goal>
                        </goals>
                        <configuration>
                            <bundleType>apiproxy</bundleType>
                            <apiName>product-api</apiName>
                            <options>update</options>
                            <directory>${project.build.directory}/apiproxies</directory>
                        </configuration>
                    </execution>
                </executions>
                <configuration>
                    <authType>oauth</authType>
                    <bearer>${apigee.bearer}</bearer>
                    <apigeeOrg>${apigee.org}</apigeeOrg>
                    <apigeeEnv>${apigee.env}</apigeeEnv>
                    <hostUrl>https://apigee.googleapis.com</hostUrl>
                </configuration>
            </plugin>
        </plugins>
    </build>

    <!-- Add Maven repositories -->
    <repositories>
        <repository>
            <id>central</id>
            <name>Maven Central</name>
            <url>https://repo.maven.apache.org/maven2</url>
        </repository>
        <repository>
            <id>apigee-releases</id>
            <name>Apigee Maven Repository</name>
            <url>https://repository.sonatype.org/content/repositories/central</url>
        </repository>
    </repositories>

    <pluginRepositories>
        <pluginRepository>
            <id>central</id>
            <name>Maven Central</name>
            <url>https://repo.maven.apache.org/maven2</url>
        </pluginRepository>
        <pluginRepository>
            <id>apigee-releases</id>
            <name>Apigee Maven Repository</name>
            <url>https://repository.sonatype.org/content/repositories/central</url>
        </pluginRepository>
    </pluginRepositories>
</project>