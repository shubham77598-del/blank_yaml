<?xml version="1.0" encoding="UTF-8"?>
<ProxyEndpoint name="default">
  <PreFlow name="PreFlow"><Request/><Response/></PreFlow>
  <Flow name="default">
    <Condition>true</Condition>
    <Request>
      <Step><Name>Verify-API-Key</Name></Step>
      <Step><Name>Quota</Name></Step>
      <Step><Name>Message-Logging</Name></Step>
    </Request>
    <Response/>
  </Flow>
  <PostFlow name="PostFlow"><Request/><Response/></PostFlow>
  <HTTPProxyConnection>
    <BasePath>/v1/sample</BasePath>
  </HTTPProxyConnection>
  <RouteRule name="default"><TargetEndpoint>default</TargetEndpoint></RouteRule>
</ProxyEndpoint>
